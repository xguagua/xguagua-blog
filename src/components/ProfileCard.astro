---
import { Image } from "astro:assets";
import Menu from "../components/ProfileCardMenu.astro";
import Footer from "../components/ProfileCardFooter.astro";
import { ORIGIN_AVATAR } from "../consts";
---

<div
  class="flex-col gap-4 mb-8 w-full sticky md:sticky lg:relative card bg-base-100 shadow-xl p-4 transition-colors"
>
      
    <div class="avatar p-4" onclick = "ClickLogic()">
      <img
        id = "AvatarSelf"
        class="mask mask-circle"
        width={300}
        height={300}
        src={ORIGIN_AVATAR}
        alt="Profile"
        loading="eager"
      />
      <script type = "text/javascript">
        var Avatar = document.getElementById("AvatarSelf");
        function TimeoutFunc() {Avatar.src = "/profile.webp";}
      
        function ClickLogic()
        {
          Avatar.src = "/profilec.webp";
          setTimeout(TimeoutFunc,300);
        }
      </script>
  </div>
  <Menu />
  <Footer />
</div>